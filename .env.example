# ============================================================
# UKUMARI · plantilla de variables de entorno
# Copia este archivo a ".env" y ajusta los valores reales.
#   cp .env.example .env
# El archivo .env NUNCA se sube a git (está en .gitignore).
# ============================================================

# ---- Base de datos (MySQL) ----
DB_HOST=mysql
DB_NAME=ukumari_db
DB_USER=ukumari_user
DB_PASS=ukumari_pass
DB_ROOT_PASS=root_pass

# ---- Puertos publicados en el host ----
WEB_PORT=8080
PMA_PORT=8081
DB_PORT=3307

# ---- Aplicación ----
APP_NAME=UKUMARI
APP_TIMEZONE=America/Lima
IGV_RATE=0.18
CURRENCY=S/

# ---- WhatsApp del local (sin "+", solo dígitos en formato internacional) ----
WHATSAPP_NUMBER=51999000000
WHATSAPP_DISPLAY=+51 999 000 000

# ---- Sistema de puntos ----
PUNTOS_POR_SOL=1
PUNTOS_CANJE_BLOQUE=100
SOLES_POR_BLOQUE_CANJE=5
